rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Prototype rules: any signed-in user (anonymous auth counts) can read/write
    // to any couple. The couple ID itself acts as the shared secret — whoever
    // has it can read and modify the data. Tighten before going public.
    match /couples/{coupleId} {
      allow read, write: if request.auth != null;

      match /dreams/{dreamId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
