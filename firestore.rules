rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Couples:
    // - Any authenticated user can read couple docs (needed to look up an invite code).
    // - Create: must include yourself as the only initial member.
    // - Update: existing members can always update; a non-member can update only
    //   to join a couple that currently has 1 member (becoming the 2nd member).
    // - Delete: not allowed via client.
    match /couples/{coupleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid;
      allow update: if request.auth != null
        && (
          request.auth.uid in resource.data.members
          || (
            resource.data.members.size() == 1
            && request.resource.data.members.size() == 2
            && request.auth.uid in request.resource.data.members
          )
        );
      allow delete: if false;
    }

    // Dreams belong to a couple — only that couple's members can read/write.
    match /couples/{coupleId}/dreams/{dreamId} {
      allow read, write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }
  }
}
